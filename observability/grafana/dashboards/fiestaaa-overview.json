  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(fiestaaa_http_requests_total[5m])) by (route, status)",
          "legendFormat": "{{route}} {{status}}"
        }
      ],
      "title": "HTTP Volume",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(fiestaaa_http_requests_total{status=~\"5..\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "title": "HTTP 5xx",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(fiestaaa_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ],
      "title": "HTTP Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "eps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(fiestaaa_auth_errors_total[5m])) by (kind)",
          "legendFormat": "{{kind}}"
        }
      ],
      "title": "Auth Errors",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "eps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(fiestaaa_email_errors_total[5m])) by (kind)",
          "legendFormat": "email {{kind}}"
        },
        {
          "expr": "sum(rate(fiestaaa_invitation_errors_total[5m])) by (kind)",
          "legendFormat": "invitation {{kind}}"
        },
        {
          "expr": "sum(rate(fiestaaa_push_errors_total[5m])) by (kind)",
          "legendFormat": "push {{kind}}"
        }
      ],
      "title": "Domain Errors",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 6,
      "targets": [
        {
          "expr": "100 * node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"}",
          "legendFormat": "root free"
        }
      ],
      "title": "Disk Free",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "id": 7,
      "targets": [
        {
          "expr": "pg_up",
          "legendFormat": "postgres up"
        },
        {
          "expr": "pg_stat_database_numbackends{datname!~\"template.*\"}",
          "legendFormat": "connections {{datname}}"
        }
      ],
      "title": "Postgres",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum(changes(container_start_time_seconds{name=~\".+\"}[1h])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Container Restarts",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"api|front|traefik|backup\"} |~ \"(?i)(error|warn|failed)\"",
          "refId": "A"
        }
      ],
      "title": "Recent Errors and Warnings",
      "type": "logs"
    }
